            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/payments/admin/shop/{{shop_id}}/bank-accounts"
          }
        },
        {
          "name": "Admin (SA): Retiros de un negocio específico",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/payments/admin/shop/{{shop_id}}/withdrawals?limit=100",
              "host": ["{{base_url}}"],
              "path": ["payments", "admin", "shop", "{{shop_id}}", "withdrawals"],
              "query": [{ "key": "limit", "value": "100" }]
            }
          }
        },
        {
          "name": "Negocio: Mis ingresos + saldo disponible",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token_casona}}" }],
            "url": "{{base_url}}/payments/my/income"
          }
        },
        {
          "name": "Negocio: Mis cuentas bancarias",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "const j = pm.response.json();",
            "if (Array.isArray(j) && j.length > 0) {",
            "  pm.collectionVariables.set('bank_account_id', j[0].id);",
