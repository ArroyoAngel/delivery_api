            "}"
          ]}}],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token_casona}}" }],
            "url": "{{base_url}}/payments/my/bank-accounts"
          }
        },
        {
          "name": "Negocio: Mis solicitudes de retiro",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token_casona}}" }],
