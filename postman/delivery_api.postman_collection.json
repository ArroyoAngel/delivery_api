{
  "info": {
    "name": "delivery_api",
    "description": "API de delivery (YaYa Eats) — NestJS en puerto 3002",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url",          "value": "http://localhost:3002/api", "type": "string" },
    { "key": "token",             "value": "", "type": "string" },
    { "key": "token_mario",       "value": "", "type": "string" },
    { "key": "token_casona",      "value": "", "type": "string" },
    { "key": "order_id",          "value": "", "type": "string" },
    { "key": "shop_id",           "value": "c0000001-0000-0000-0000-000000000000", "type": "string" },
    { "key": "menu_item_id",      "value": "", "type": "string" },
    { "key": "address_id",        "value": "", "type": "string" },
    { "key": "group_id",          "value": "", "type": "string" },
    { "key": "payment_reference", "value": "", "type": "string" },
    { "key": "withdrawal_id",     "value": "", "type": "string" },
    { "key": "bank_account_id",   "value": "", "type": "string" },
    { "key": "webhook_secret",       "value": "webhook_secret_dev_2024", "type": "string" },
    { "key": "credit_package_id",    "value": "", "type": "string" },
    { "key": "credit_purchase_id",   "value": "", "type": "string" },
    { "key": "credit_reference",     "value": "", "type": "string" }
  ],
  "item": [

    {
      "name": "Auth",
      "item": [
        {
          "name": "Login — luis (client + rider + super_admin)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "const j = pm.response.json();",
            "if (j.accessToken) { pm.collectionVariables.set('token', j.accessToken); console.log('Token luis guardado'); }"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/login",
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"luis@gmail.com\",\n  \"password\": \"luis123\"\n}" }
          }
        },
        {
          "name": "Login — mario (shop owner — Pizzería)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "const j = pm.response.json();",
            "if (j.accessToken) { pm.collectionVariables.set('token_mario', j.accessToken); console.log('Token mario guardado'); }"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/login",
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"mario@pizzeria.com\",\n  \"password\": \"mario123\"\n}" }
          }
        },
        {
          "name": "Login — admin.casona (shop admin — La Casona)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "const j = pm.response.json();",
            "if (j.accessToken) { pm.collectionVariables.set('token_casona', j.accessToken); console.log('Token casona guardado'); }"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/login",
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@lacasona.com\",\n  \"password\": \"casona123\"\n}" }
          }
        },
        {
          "name": "Registrar usuario",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/register",
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"nuevo@test.com\",\n  \"password\": \"pass123\",\n  \"firstName\": \"Nuevo\",\n  \"lastName\": \"Usuario\"\n}" }
          }
        },
        {
          "name": "Mi perfil",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/auth/me"
          }
        }
      ]
    },

    {
      "name": "Usuarios",
      "item": [
        {
          "name": "Actualizar perfil",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/users/profile",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Luis\",\n  \"lastName\": \"García\",\n  \"phone\": \"+591 70000000\"\n}"
            }
          }
        }
      ]
    },

    {
      "name": "Negocios (Shops)",
      "item": [
        {
          "name": "Listar negocios",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/restaurants"
          }
        },
        {
          "name": "Buscar negocio",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/restaurants?search=pizza",
              "host": ["{{base_url}}"],
              "path": ["restaurants"],
              "query": [{ "key": "search", "value": "pizza" }]
            }
          }
        },
        {
          "name": "Categorías de negocios",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/restaurants/categories"
          }
        },
        {
          "name": "Detalle negocio + menú",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "const j = pm.response.json();",
            "if (j.menu && j.menu.length > 0) {",
            "  pm.collectionVariables.set('menu_item_id', j.menu[0].id);",
            "  console.log('menu_item_id guardado:', j.menu[0].id);",
            "}"
          ]}}],
          "request": {
            "method": "GET",
            "url": "{{base_url}}/restaurants/{{shop_id}}"
          }
        }
      ]
    },

    {
      "name": "Pedidos — Cliente",
      "item": [
        {
          "name": "Crear pedido (delivery)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "const j = pm.response.json();",
            "if (j.id) { pm.collectionVariables.set('order_id', j.id); console.log('order_id guardado:', j.id); }",
            "if (j.paymentReference) { pm.collectionVariables.set('payment_reference', j.paymentReference); console.log('payment_reference guardado:', j.paymentReference); }"
          ]}}],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/orders",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"restaurantId\": \"{{shop_id}}\",\n  \"items\": [\n    { \"menuItemId\": \"{{menu_item_id}}\", \"quantity\": 2 }\n  ],\n  \"deliveryType\": \"delivery\",\n  \"deliveryAddress\": \"Av. 6 de Agosto 1234\",\n  \"notes\": \"Sin cebolla por favor\"\n}"
            }
          }
        },
        {
          "name": "Mis pedidos",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/orders"
          }
        },
        {
          "name": "Detalle de pedido",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/orders/{{order_id}}"
          }
        },
        {
          "name": "Cancelar pedido",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/orders/{{order_id}}/cancel"
          }
        },
        {
          "name": "(SuperAdmin) Forzar estado genérico — /orders/:id/status",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/orders/{{order_id}}/status",
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"confirmado\"\n}" }
          }
        }
      ]
    },

    {
      "name": "Pedidos — Negocio (admin.casona)",
      "item": [
        {
          "name": "Ver pedidos de mi negocio",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token_casona}}" }],
            "url": "{{base_url}}/orders/shop/mine"
          }
        },
        {
          "name": "Marcar preparando (confirmado → preparando)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token_casona}}" }
            ],
            "url": "{{base_url}}/orders/{{order_id}}/preparing"
          }
        },
        {
          "name": "Marcar LISTO — dispara agrupamiento",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "const j = pm.response.json();",
            "console.log('Grupos creados:', j.groupsCreated);",
            "if (j.groupsCreated > 0) console.log('¡Se armó un grupo! Revisá Rider > Grupos disponibles');"
          ]}}],
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token_casona}}" }
            ],
            "url": "{{base_url}}/orders/{{order_id}}/ready"
          }
        }
      ]
    },

    {
      "name": "Rider — Delivery (luis@gmail.com)",
      "item": [
        {
          "name": "Grupos disponibles",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "const j = pm.response.json();",
            "if (Array.isArray(j) && j.length > 0) {",
            "  pm.collectionVariables.set('group_id', j[0].id);",
            "  console.log('group_id guardado:', j[0].id, '— pedidos:', j[0].orders?.length);",
            "}"
          ]}}],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/rider/groups/available"
          }
        },
        {
          "name": "Aceptar grupo",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/rider/groups/{{group_id}}/accept"
          }
        },
        {
          "name": "Mi entrega activa",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/rider/groups/my-active"
          }
        },
        {
          "name": "Marcar en camino (listo → en_camino)",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/orders/{{order_id}}/on-the-way"
          }
        },
        {
          "name": "Marcar entregado/finalizado (en_camino → entregado)",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/orders/{{order_id}}/done"
          }
        }
      ]
    },

    {
      "name": "Direcciones",
      "item": [
        {
          "name": "Mis direcciones",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/addresses"
          }
        },
        {
          "name": "Crear dirección",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "const j = pm.response.json();",
            "if (j.id) { pm.collectionVariables.set('address_id', j.id); console.log('address_id guardado:', j.id); }"
          ]}}],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/addresses",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Casa\",\n  \"street\": \"Av. 6 de Agosto\",\n  \"number\": \"1234\",\n  \"reference\": \"Frente al parque\",\n  \"latitude\": -16.5000,\n  \"longitude\": -68.1500,\n  \"isDefault\": true\n}"
            }
          }
        },
        {
          "name": "Actualizar dirección",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/addresses/{{address_id}}",
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Casa actualizada\",\n  \"street\": \"Av. Arce\",\n  \"number\": \"2000\"\n}" }
          }
        },
        {
          "name": "Eliminar dirección",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/addresses/{{address_id}}"
          }
        }
      ]
    },

    {
      "name": "Pagos — Webhooks y Admin",
      "item": [
        {
          "name": "Webhook: Confirmar pago por referencia",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-payment-secret", "value": "{{webhook_secret}}" }
            ],
            "url": "{{base_url}}/payments/confirm",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reference\": \"{{payment_reference}}\",\n  \"paidAmount\": 100,\n  \"bankProvider\": \"BNB\",\n  \"bankTransactionId\": \"BNB-TX-POSTMAN-001\"\n}"
            }
          }
        },
        {
          "name": "Admin (SA): Resumen financiero global",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/payments/admin/summary"
          }
        },
        {
          "name": "Admin (SA): Listado de pagos",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/payments/admin/list?limit=100",
              "host": ["{{base_url}}"],
              "path": ["payments", "admin", "list"],
              "query": [{ "key": "limit", "value": "100" }]
            }
          }
        },
        {
          "name": "Admin (SA): Cuentas bancarias (todos)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/payments/admin/bank-accounts"
          }
        },
        {
          "name": "Admin (SA): Solicitudes de retiro (todas)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "const j = pm.response.json();",
            "if (Array.isArray(j) && j.length > 0) {",
            "  pm.collectionVariables.set('withdrawal_id', j[0].id);",
            "  console.log('withdrawal_id guardado:', j[0].id, '— estado:', j[0].status);",
            "}"
          ]}}],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/payments/admin/withdrawals?limit=100",
              "host": ["{{base_url}}"],
              "path": ["payments", "admin", "withdrawals"],
              "query": [{ "key": "limit", "value": "100" }]
            }
          }
        },
        {
          "name": "Admin (SA): Aprobar o rechazar retiro",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/payments/admin/withdrawals/{{withdrawal_id}}/process",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"action\": \"completed\",\n  \"externalTransferId\": \"BNB-TRANSFER-001\",\n  \"notes\": \"Transferido el 21/03/2026\"\n}"
            }
          }
        },
        {
          "name": "Admin (SA): Ingresos de un negocio específico",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/payments/admin/shop/{{shop_id}}/income"
          }
        },
        {
          "name": "Admin (SA): Cuentas bancarias de un negocio específico",
          "request": {
